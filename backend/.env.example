HOST=127.0.0.1
PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000

# Required: create OAuth app/token setup in your Lichess account and put client id.
LICHESS_CLIENT_ID=offline-lichess-desktop-v1

# Optional depending on your Lichess OAuth app configuration.
LICHESS_CLIENT_SECRET=

# Space separated scopes.
LICHESS_SCOPES=board:play challenge:read challenge:write preference:read
